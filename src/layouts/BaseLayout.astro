---
import "../styles/global.css";
import { siteConfig } from "../config/site";
import SiteFooter from "../components/common/SiteFooter.astro";
import SiteHeader from "../components/common/SiteHeader.astro";
import {
  createBreadcrumbList,
  serializeStructuredData,
  type StructuredDataNode,
} from "../utils/structured-data";

interface Props {
  title?: string;
  description?: string;
  home?: boolean;
  noindex?: boolean;
  showHeader?: boolean;
  showFooter?: boolean;
  canonical?: string;
  openGraphImage?: string;
  structuredData?: StructuredDataNode | StructuredDataNode[];
}

const {
  title,
  description = siteConfig.description,
  home = false,
  noindex = false,
  showHeader = true,
  showFooter = true,
  canonical,
  openGraphImage,
  structuredData,
} = Astro.props;
const documentTitle = home
  ? (title ?? siteConfig.name)
  : `${title ?? siteConfig.name} | ${siteConfig.name}`;
const canonicalUrl = canonical ?? `${siteConfig.domain}${Astro.url.pathname}`;
const resolvedOpenGraphImage =
  openGraphImage ?? siteConfig.assets.openGraphImage;
const structuredNodes = structuredData
  ? Array.isArray(structuredData)
    ? [...structuredData]
    : [structuredData]
  : [];

if (!home && !noindex && title) {
  structuredNodes.unshift(
    createBreadcrumbList(siteConfig.domain, canonicalUrl, title),
  );
}

const structuredGraph = serializeStructuredData(structuredNodes);
---

<!doctype html>
<html lang={siteConfig.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={siteConfig.assets.favicon} type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={siteConfig.locale.replace("-", "_")} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {
      resolvedOpenGraphImage && (
        <>
          <meta property="og:image" content={resolvedOpenGraphImage} />
          <meta name="twitter:card" content="summary_large_image" />
        </>
      )
    }
    {
      structuredGraph && (
        <script
          is:inline
          type="application/ld+json"
          set:html={structuredGraph}
        />
      )
    }
    <title>{documentTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Aller au contenu principal</a>
    {showHeader && <SiteHeader />}
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    {showFooter && <SiteFooter />}
  </body>
</html>
