---
interface Props {
  number: string;
  title: string;
  description: string;
  points: readonly string[];
}

const { number, title, description, points } = Astro.props;
---

<article class="method-step">
  <div class="method-step__heading">
    <span aria-hidden="true">{number}</span>
    <div>
      <h3>{title}</h3>
      <p>{description}</p>
    </div>
  </div>
  <ul aria-label={`Éléments considérés pendant l’étape ${title}`}>
    {points.map((point) => <li>{point}</li>)}
  </ul>
</article>

<style>
  .method-step {
    display: grid;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .method-step__heading {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: var(--space-md);
  }

  .method-step__heading > span {
    color: var(--color-focus);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  h3 {
    margin-bottom: var(--space-xs);
  }

  p,
  li {
    color: var(--color-text-muted);
  }

  p {
    margin: 0;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin: 0 0 0 calc(2.5rem + var(--space-md));
    padding: 0;
    list-style: none;
  }

  li {
    padding: 0.4rem 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface-elevated);
    font-size: 0.82rem;
  }

  @media (min-width: 48rem) {
    .method-step {
      grid-template-columns: minmax(0, 1.1fr) minmax(15rem, 0.9fr);
      align-items: start;
    }

    ul {
      margin-left: 0;
    }
  }
</style>
