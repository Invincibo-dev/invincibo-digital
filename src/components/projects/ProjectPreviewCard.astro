---
import Badge from "../common/Badge.astro";
import Card from "../common/Card.astro";
import {
  getPublicProjectTitle,
  type ProjectVisibility,
} from "../../utils/projects";

interface Props {
  internalTitle: string;
  publicTitle?: string;
  visibility: ProjectVisibility;
  category: string;
  summary: string;
  capabilities?: string[];
  caseStudyReady?: boolean;
}

const {
  internalTitle,
  publicTitle,
  visibility,
  category,
  summary,
  capabilities = [],
  caseStudyReady = false,
} = Astro.props;
const title = getPublicProjectTitle({
  title: internalTitle,
  publicTitle,
  visibility,
});
---

<Card class="project-card">
  <div class="project-body">
    <Badge>{category}</Badge>
    <h3>{title}</h3>
    <p>{summary}</p>
    {
      capabilities.length > 0 && (
        <ul>
          {capabilities.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      )
    }
    {!caseStudyReady && <p class="status">Étude de cas en préparation</p>}
  </div>
</Card>

<style>
  :global(.project-card) {
    position: relative;
  }

  .project-body {
    padding-top: var(--space-sm);
  }

  h3 {
    margin: var(--space-md) 0 var(--space-sm);
  }

  p,
  li {
    color: var(--color-text-muted);
  }

  ul {
    padding-left: var(--space-lg);
  }

  .status {
    margin: var(--space-lg) 0 0;
    color: var(--color-focus);
    font-size: 0.85rem;
    font-weight: 700;
  }
</style>
