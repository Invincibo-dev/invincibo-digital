---
import Card from "../common/Card.astro";

interface Props {
  number: string;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<Card class="problem-card">
  <span class="number" aria-hidden="true">{number}</span>
  <h3>{title}</h3>
  <p>{description}</p>
</Card>

<style>
  .number {
    color: var(--color-focus);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  h3 {
    margin: var(--space-md) 0 var(--space-sm);
  }

  p {
    margin: 0;
    color: var(--color-text-muted);
  }
</style>
