---
import Container from "../common/Container.astro";
import Section from "../common/Section.astro";
import SectionHeading from "../common/SectionHeading.astro";
import { siteConfig } from "../../config/site";
---

<Section id="a-propos">
  <Container>
    <div class="founder-grid">
      <div>
        <SectionHeading
          eyebrow="À propos"
          title="Une approche proche de vos opérations"
        />
        <p class="name">{siteConfig.founder.name}</p>
        <p class="role">{siteConfig.founder.role}</p>
        <p class="statement">{siteConfig.founder.shortBio}</p>
        <a class="about-link" href="/a-propos/">Découvrir notre approche</a>
      </div>
    </div>
  </Container>
</Section>

<style>
  .founder-grid {
    max-width: 52rem;
  }

  .name {
    margin: var(--space-xl) 0 0;
    font-size: 1.35rem;
    font-weight: 700;
  }

  .role {
    margin: 0;
    color: var(--color-focus);
  }

  .statement {
    margin: var(--space-lg) 0 0;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .about-link {
    display: inline-block;
    margin-top: var(--space-lg);
    font-weight: 700;
  }
</style>
