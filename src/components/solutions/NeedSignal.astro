---
import Icon from "../common/Icon.astro";

interface Props {
  text: string;
}

const { text } = Astro.props;
---

<li class="signal"><Icon name="check" size={19} /><span>{text}</span></li>

<style>
  .signal {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    padding-block: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .signal :global(svg) {
    flex: 0 0 auto;
    margin-top: 0.2rem;
    color: var(--color-focus);
  }
</style>
